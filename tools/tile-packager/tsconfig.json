{
	"compilerOptions": {
		"target": "es2022",
		"module": "esnext",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": false,
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"types": ["bun-types"],
		"baseUrl": ".",
		"paths": {
			"$lib/*": ["../../src/lib/*"]
		}
	},
	"include": ["src/**/*.ts"]
}
