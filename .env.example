# Cesium Ion Access Token (free at https://cesium.com/ion/tokens)
VITE_CESIUM_ION_TOKEN=your-cesium-ion-token-here

# Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Offline Tile Server URL (set when running with local tile-server for Pi 5 offline mode)
# Leave unset for normal Cesium Ion online mode.
# VITE_TILE_SERVER_URL=http://localhost:8888

# Sentinel-2 imagery via AWS S3 (requires tiling proxy for full z/x/y Cesium support)
# VITE_SENTINEL2=true
