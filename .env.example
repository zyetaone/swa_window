# Required: Cesium Ion access token (free at https://cesium.com/ion/tokens)
VITE_CESIUM_ION_TOKEN=your-cesium-ion-token-here

# Optional: Mapbox Satellite token. If omitted, the app falls back to ESRI World Imagery.
# VITE_MAPBOX_TOKEN=your-mapbox-token-here

# Optional: Local tile server for offline Raspberry Pi deployments.
# Leave unset for the normal online imagery flow.
# VITE_TILE_SERVER_URL=http://localhost:8888

# Optional: Experimental Sentinel-2 imagery mode. Requires a tiling proxy.
# VITE_SENTINEL2=false
