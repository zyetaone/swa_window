{
	"name": "aero-dynamicwindow",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"postinstall": "chmod +x node_modules/.bin/* 2>/dev/null || true",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"generate-textures": "npx tsx --env-file=.env scripts/generate-textures.ts",
		"server": "bun run server/src/index.ts",
		"dev:all": "bun run dev & bun run server"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.51.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/three": "^0.182.0",
		"svelte": "^5.50.3",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-static-copy": "^3.2.0"
	},
	"dependencies": {
		"@google/genai": "^1.41.0",
		"@threlte/core": "^8.3.1",
		"@threlte/extras": "^9.7.1",
		"cesium": "^1.138.0",
		"three": "^0.182.0"
	}
}
