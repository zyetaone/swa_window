{
	"name": "aero-dynamicwindow",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"postinstall": "chmod +x node_modules/.bin/* 2>/dev/null || true",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"generate-textures": "bun run scripts/generate-textures.ts",
		"prefetch-tiles": "bun run scripts/prefetch-tiles.ts",
		"build-pmtiles": "bun run scripts/build-pmtiles.ts",
		"serve": "bun run server.ts",
		"start": "bun run build && bun run server.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/svelte": "^5.3.1",
		"@types/multicast-dns": "^7.2.4",
		"@types/three": "^0.183.1",
		"@vitest/ui": "^4.1.5",
		"bun-types": "^1.3.13",
		"happy-dom": "^20.9.0",
		"svelte": "^5.55.4",
		"svelte-check": "^4.4.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.2",
		"vite-plugin-static-copy": "^3.4.0",
		"vitest": "^4.1.5"
	},
	"dependencies": {
		"@dvt3d/maplibre-three-plugin": "^1.6.0",
		"@svelte-maplibre-gl/pmtiles": "^1.0.3",
		"@takram/three-atmosphere": "^0.18.0",
		"@takram/three-clouds": "^0.7.4",
		"@takram/three-geospatial": "^0.8.0",
		"@takram/three-geospatial-effects": "^0.6.2",
		"@threlte/core": "^8.5.9",
		"@threlte/extras": "^9.14.8",
		"cesium": "^1.140.0",
		"maplibre-gl": "^5.23.0",
		"multicast-dns": "^7.2.5",
		"pmtiles": "^4.4.1",
		"postprocessing": "^6.39.1",
		"svelte-maplibre-gl": "^1.0.3",
		"three": "^0.183.2"
	}
}
