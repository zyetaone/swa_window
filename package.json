{
	"name": "aero-dynamicwindow",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"postinstall": "chmod +x node_modules/.bin/* 2>/dev/null || true",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"generate-textures": "bun run scripts/generate-textures.ts",
		"prefetch-tiles": "bun run scripts/prefetch-tiles.ts",
		"build-pmtiles": "bun run scripts/build-pmtiles.ts",
		"serve": "bun run server.ts",
		"start": "bun run build && bun run server.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.51.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@testing-library/svelte": "^5.3.1",
		"@vitest/ui": "^4.1.4",
		"bun-types": "^1.3.12",
		"happy-dom": "^20.9.0",
		"svelte": "^5.50.3",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-static-copy": "^3.2.0",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"@svelte-maplibre-gl/pmtiles": "^1.0.3",
		"cesium": "^1.138.0",
		"maplibre-gl": "^5.23.0",
		"pmtiles": "^4.4.1",
		"svelte-maplibre-gl": "^1.0.3"
	}
}
