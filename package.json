{
	"name": "zyeta-aero",
	"private": true,
	"type": "module",
	"workspaces": ["packages/*"],
	"scripts": {
		"start": "bun run dev:server & bun run dev:tiles & bun run dev:admin & bun run dev",
		"dev": "bun run --filter @zyeta/display dev",
		"dev:server": "bun run --filter @zyeta/server dev",
		"dev:admin": "bun run --filter @zyeta/admin dev",
		"dev:tiles": "bun run --filter @zyeta/tile-server dev",
		"build": "bun run --filter @zyeta/display build",
		"check": "bun run --filter @zyeta/display check",
		"tiles:estimate": "bun run --filter @zyeta/tile-packager start -- --estimate",
		"tiles:pack": "bun run --filter @zyeta/tile-packager start"
	}
}
