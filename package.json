{
	"name": "aero-dynamicwindow",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"postinstall": "chmod +x node_modules/.bin/* 2>/dev/null || true",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"generate-textures": "npx tsx --env-file=.env scripts/generate-textures.ts",
		"serve": "bun run server.ts",
		"start": "bun run build && bun run server.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.51.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"bun-types": "^1.3.12",
		"svelte": "^5.50.3",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-static-copy": "^3.2.0"
	},
	"dependencies": {
		"cesium": "^1.138.0"
	}
}
